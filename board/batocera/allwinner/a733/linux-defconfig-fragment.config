# Orange Pi BSP platform — required for ALL BSP drivers (CCU, MMC, display, USB)
# Without AW_BSP, AW_CCU won't enable and every peripheral is clockless at boot.
# Chain: AW_BSP → AW_CCU → AW_SUN60IW2_CCU (auto via ARCH_SUN60IW2 default)
CONFIG_AW_BSP=y
CONFIG_AW_KERNEL_ORIGIN=y
CONFIG_ARCH_SUN60I=y
CONFIG_ARCH_SUN60IW2=y
CONFIG_AW_IC_BOARD=y
CONFIG_AW_SOC_NAME="A733"
# disable mainline sunxi-ng CCU — BSP CCU (bsp/drivers/clk/sunxi-ng/) replaces it.
# Both compile the same helper files (ccu_mux, ccu_sdm, etc.) causing duplicate symbols.
CONFIG_SUNXI_CCU=n
# mainline sunxi-mmc conflicts with BSP AW_MMC — both register as 'sunxi-mmc'
CONFIG_MMC_SUNXI=n
# BSP input sensor init module references irq_to_desc which is not exported
CONFIG_AW_INPUT_SENSORINIT=n
# BSP MMC driver — matches allwinner,sunxi-mmc-v5p3x in the A733 DTS
# Mainline SDHCI/DWMMC don't match this compatible string
CONFIG_AW_MMC_HSQ=y
CONFIG_AW_MMC=y
CONFIG_AW_MMC_V5P3X=y

# required for evmapy
CONFIG_INPUT_UINPUT=y

# required for squashfs + overlayfs
CONFIG_NLS_ISO8859_1=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y

# required for AIC8800 USB WiFi (dock and handheld)
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y

# disable Broadcom SDIO WiFi — not present on Cubie A7S (uses AIC8800 USB)
# bcmdhd references sunxi_wlan_* symbols that aren't built, causing modpost errors
CONFIG_BCMDHD=n

# mainline MFD AXP20X conflicts with BSP AW_MFD_AXP2101 — duplicate axp20x_* symbols
CONFIG_MFD_AXP20X=n
CONFIG_MFD_AXP20X_I2C=n
CONFIG_MFD_AXP20X_RSB=n

# AXP8191 PMIC driver chain — provides vmmc/vqmmc regulators that sdc0 depends on
# AW_DMA: BSP DMA driver — required by AW_TWI (Kconfig dependency)
# AW_TWI: BSP I2C driver matching allwinner,sunxi-twi-v101 (s_twi0 bus the PMIC is on)
# AW_MFD_AXP2101_I2C: MFD driver that recognizes x-powers,axp8191 via of_match
# AW_REGULATOR_AXP2101: exposes reg_dc1sw2 and reg_cldo5 to the regulator framework
CONFIG_AW_DMA=y
CONFIG_AW_TWI=y
CONFIG_AW_MFD_AXP2101_I2C=y
CONFIG_AW_REGULATOR_AXP2101=y
