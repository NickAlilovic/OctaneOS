# Wakeupgen is the root interrupt-parent in sun60iw2p1.dtsi — ALL pinctrl/GPIO interrupts
# route through it. Without this, platform_get_irq() for the PIO node returns EPROBE_DEFER
# forever, causing pinctrl/DMA/TWI/MMC to never probe and LABEL=BATOCERA to fail.
CONFIG_AW_WAKEUPGEN=y

# intc-nmi@7010320 uses allwinner,sun8i-nmi — AXP8191 PMIC interrupt-parent.
# Without this, AXP8191 fails EPROBE_DEFER at 5 usecs (interrupt domain not found),
# its aldo1 regulator never registers, twi0 twi-supply fails at 0 usecs, sdc0 defers.
CONFIG_AW_SUN8I_NMI=y

# Orange Pi BSP platform — required for ALL BSP drivers (CCU, MMC, display, USB)
# Without AW_BSP, AW_CCU won't enable and every peripheral is clockless at boot.
# Chain: AW_BSP → AW_CCU → AW_SUN60IW2_CCU (auto via ARCH_SUN60IW2 default)
CONFIG_AW_BSP=y
CONFIG_AW_KERNEL_ORIGIN=y
CONFIG_ARCH_SUN60I=y
CONFIG_ARCH_SUN60IW2=y
CONFIG_AW_IC_BOARD=y
CONFIG_AW_SOC_NAME="A733"
# disable mainline sunxi-ng CCU — BSP CCU (bsp/drivers/clk/sunxi-ng/) replaces it.
# Both compile the same helper files (ccu_mux, ccu_sdm, etc.) causing duplicate symbols.
CONFIG_SUNXI_CCU=n
# mainline sunxi-mmc conflicts with BSP AW_MMC — both register as 'sunxi-mmc'
CONFIG_MMC_SUNXI=n
# BSP input sensor init module references irq_to_desc which is not exported
CONFIG_AW_INPUT_SENSORINIT=n
# BSP MMC driver — matches allwinner,sunxi-mmc-v5p3x in the A733 DTS
# Mainline SDHCI/DWMMC don't match this compatible string
CONFIG_AW_MMC_HSQ=y
CONFIG_AW_MMC=y
CONFIG_AW_MMC_V5P3X=y

# required for evmapy
CONFIG_INPUT_UINPUT=y

# required for squashfs + overlayfs
CONFIG_NLS_ISO8859_1=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y

# required for AIC8800 USB WiFi (dock and handheld)
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y

# disable Broadcom SDIO WiFi — not present on Cubie A7S (uses AIC8800 USB)
# bcmdhd references sunxi_wlan_* symbols that aren't built, causing modpost errors
CONFIG_BCMDHD=n

# mainline MFD AXP20X conflicts with BSP AW_MFD_AXP2101 — duplicate axp20x_* symbols
CONFIG_MFD_AXP20X=n
CONFIG_MFD_AXP20X_I2C=n
CONFIG_MFD_AXP20X_RSB=n

# AXP8191 PMIC driver chain — provides vmmc/vqmmc regulators that sdc0 depends on
# AW_DMA: BSP DMA driver — required by AW_TWI (Kconfig dependency)
# AW_TWI: BSP I2C driver matching allwinner,sunxi-twi-v101 (s_twi0 bus the PMIC is on)
# AW_MFD_AXP2101_I2C: MFD driver that recognizes x-powers,axp8191 via of_match
# AW_REGULATOR_AXP2101: exposes reg_dc1sw2 and reg_cldo5 to the regulator framework
CONFIG_AW_DMA=y
CONFIG_AW_TWI=y
CONFIG_AW_MFD_AXP2101_I2C=y
CONFIG_AW_REGULATOR_AXP2101=y

# BSP DRM/KMS display stack — USB-C DisplayPort output (only display on Cubie A7S)
# Cubie A7S has no physical HDMI port; all video goes via USB-C DP alt mode.
# Pipeline: DE(5000000) → TCON4(5731000) → eDP0(5740000) → Cadence SERDES → USB-C
#
# AW_DRM: BSP KMS/DRM driver wrapping the Allwinner Display Engine
# AW_DRM_EDP: DP output driver — matches allwinner,drm-dp on edp0@5740000
# AW_CADENCE_COMBOPHY: Cadence SERDES combo PHY — matches allwinner,cadence-combophy
#   (drives combo-phy0@6c01000 which provides the DP lanes to the USB-C connector)
# TYPEC_MUX_SUNXI_PHY_SWITCHER: switches USB-C port into DP alt mode at boot
#   (allwinner,sunxi-phy-switcher — referenced in /chosen/phy_switcher in DTS)
CONFIG_DRM=y
# AW_PCK600_DOMAINS: power domain provider for display subsystem (vo0, vo1)
# pck-600@7060000 (allwinner,sun60iw2-pck-600) supplies PCK_VO and PCK_VO1
# power domains that vo0/vo1 depend on — without this they EPROBE_DEFER forever.
CONFIG_AW_PCK600_DOMAINS=y
CONFIG_AW_DRM=y
CONFIG_AW_DRM_DE=y
CONFIG_AW_DRM_TCON=y
CONFIG_AW_DRM_TCON_TV=y
CONFIG_AW_DRM_TCON_TOP=y
CONFIG_AW_DRM_EDP=y
# AW_DRM_TRILINEAR_EDP14: low-level DP 1.4 controller for edp0
#   selects AW_DRM_EDP_CONTROLLER_USED (exposes real HDCP stubs to sunxi_edp.c)
#   selects AW_DRM_DP_HDCP (provides sunxi_dp_get_hw_hdcp_ops in trilinear_dp14.c)
# Without this, sunxi_edp.c gets implicit-declaration errors for HDCP functions.
CONFIG_AW_DRM_TRILINEAR_EDP14=y
CONFIG_AW_CADENCE_COMBOPHY=y
CONFIG_TYPEC_MUX_SUNXI_PHY_SWITCHER=y
# USB_SUNXI_TYPEC is auto-selected by AW_TYPEC_HUSB311 below

# HUSB311 TypeC controller — required for USB-C DP Alt Mode negotiation
# Without this, the HUSB311 at s_twi1/0x4e never initializes, the USB-C
# port never negotiates DP Alt Mode, the combo-phy never switches, and
# edp0 reports "combo-phy not setting, maybe not used!" at bind time.
# AW_TYPEC_HUSB311 is the BSP-specific symbol (bsp/drivers/power/Kconfig).
# It selects TYPEC_TCPM, TYPEC_TCPCI, USB_SUNXI_TYPEC, and AW_POWER_NOTIFIER.
# Note: TYPEC_HUSB311 (bsp/drivers/usb/typec/tcpm/Kconfig) is a different,
# unrelated symbol — using it silently built nothing.
CONFIG_AW_TYPEC_HUSB311=y
# TYPEC core must be =y (not =m) — TCPCI/TCPM can't link built-in into a module framework
CONFIG_TYPEC=y
