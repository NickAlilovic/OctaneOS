# Wakeupgen is the root interrupt-parent in sun60iw2p1.dtsi — ALL pinctrl/GPIO interrupts
# route through it. Without this, platform_get_irq() for the PIO node returns EPROBE_DEFER
# forever, causing pinctrl/DMA/TWI/MMC to never probe and LABEL=BATOCERA to fail.
CONFIG_AW_WAKEUPGEN=y

# intc-nmi@7010320 uses allwinner,sun8i-nmi — AXP8191 PMIC interrupt-parent.
# Without this, AXP8191 fails EPROBE_DEFER at 5 usecs (interrupt domain not found),
# its aldo1 regulator never registers, twi0 twi-supply fails at 0 usecs, sdc0 defers.
CONFIG_AW_SUN8I_NMI=y

# BSP platform — required for ALL BSP drivers (CCU, MMC, display, USB)
# Chain: AW_BSP → AW_CCU → AW_SUN60IW2_CCU (auto via ARCH_SUN60IW2 default)
CONFIG_AW_BSP=y
CONFIG_AW_KERNEL_ORIGIN=y
CONFIG_ARCH_SUN60I=y
CONFIG_ARCH_SUN60IW2=y
CONFIG_AW_IC_BOARD=y
CONFIG_AW_SOC_NAME="A733"

# disable mainline sunxi-ng CCU — BSP CCU replaces it (duplicate symbols)
CONFIG_SUNXI_CCU=n

# mainline sunxi-mmc conflicts with BSP AW_MMC — both register as 'sunxi-mmc'
CONFIG_MMC_SUNXI=n

# BSP input sensor init references irq_to_desc which is not exported
CONFIG_AW_INPUT_SENSORINIT=n

# BSP MMC driver — matches allwinner,sunxi-mmc-v5p3x in the A733 DTS
CONFIG_AW_MMC_HSQ=y
CONFIG_AW_MMC=y
CONFIG_AW_MMC_V5P3X=y

# Onboard Gigabit Ethernet — BSP STMMAC driver for allwinner,sunxi-gmac-210
CONFIG_AW_STMMAC_ETH=y

# MediaTek MT7921K PCIe WiFi (M.2 2230 dock streaming radio)
CONFIG_MT7921E=y

# USB-A host controller — Allwinner BSP EHCI/OHCI for the physical USB-A port
CONFIG_USB_SUNXI_HCD=y
CONFIG_USB_SUNXI_HCI=y
CONFIG_USB_EHCI_HCD_SUNXI=y
CONFIG_USB_SUNXI_EHCI1=y
CONFIG_USB_OHCI_HCD_SUNXI=y
CONFIG_USB_SUNXI_OHCI1=y

# USB HID — required for USB gamepads, keyboards, and mice
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y

# required for evmapy
CONFIG_INPUT_UINPUT=y

# required for squashfs + overlayfs
CONFIG_NLS_ISO8859_1=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y

# required for AIC8800 USB WiFi
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y

# disable Broadcom SDIO WiFi — not present (uses AIC8800 USB); bcmdhd references
# sunxi_wlan_* symbols not built, causing modpost errors
CONFIG_BCMDHD=n

# mainline MFD AXP20X conflicts with BSP AW_MFD_AXP2101 — duplicate axp20x_* symbols
CONFIG_MFD_AXP20X=n
CONFIG_MFD_AXP20X_I2C=n
CONFIG_MFD_AXP20X_RSB=n

# AXP8191 PMIC driver chain
# AW_DMA: BSP DMA driver — required by AW_TWI (Kconfig dependency)
# AW_TWI: BSP I2C driver matching allwinner,sunxi-twi-v101
# AW_MFD_AXP2101_I2C: MFD driver that recognizes x-powers,axp8191
# AW_REGULATOR_AXP2101: exposes regulators to the regulator framework
CONFIG_AW_DMA=y
CONFIG_AW_TWI=y
CONFIG_AW_MFD_AXP2101_I2C=y
CONFIG_AW_REGULATOR_AXP2101=y

# BSP DRM/KMS display stack — USB-C DisplayPort output
# Pipeline: DE(5000000) → TCON4(5731000) → eDP0(5740000) → Cadence SERDES → USB-C
CONFIG_DRM=y
CONFIG_AW_PCK600_DOMAINS=y
CONFIG_AW_DRM=y
CONFIG_AW_DRM_DE=y
CONFIG_AW_DRM_TCON=y
CONFIG_AW_DRM_TCON_TV=y
CONFIG_AW_DRM_TCON_TOP=y
CONFIG_AW_DRM_EDP=y
CONFIG_AW_DRM_TRILINEAR_EDP14=y
CONFIG_AW_CADENCE_COMBOPHY=y
CONFIG_TYPEC_MUX_SUNXI_PHY_SWITCHER=y

# HUSB311 TypeC controller — required for USB-C DP Alt Mode negotiation
# AW_TYPEC_HUSB311 selects TYPEC_TCPM, TYPEC_TCPCI, USB_SUNXI_TYPEC, AW_POWER_NOTIFIER
CONFIG_AW_TYPEC_HUSB311=y
# TYPEC core must be =y (not =m) — TCPCI/TCPM can't link built-in into a module framework
CONFIG_TYPEC=y
CONFIG_TYPEC_DP_ALTMODE=y

# USB_SUNXI_DWC3: BSP gate for the Allwinner USB3 DWC3 glue stack
# usbc2@12 uses compatible "allwinner,sunxi-plat-dwc3" (DWC3_SUNXI_PLAT)
# HUSB311 defers forever if the DWC3 role-switch endpoint it references never probes
CONFIG_USB_SUNXI_DWC3=y
CONFIG_DWC3_SUNXI_PLAT=y
CONFIG_PHY_SUNXI_PLAT=y

# =============================================================================
# Disable BSP drivers not needed for OctaneOS bringup
#
# AW_VIDEO_ENCODER_DECODER: cedar-ve hardware video codec — default y in Kconfig
# but cedar_ve.h is generated by the Allwinner SDK and not in the BSP git tree.
# Hardware video decode is not required for EmulationStation/RetroArch bringup.
# AW_VIDEO_GOOGLE_DECODER: google VP9/AV1 decoder — same situation, not needed.
# =============================================================================
CONFIG_AW_VIDEO_ENCODER_DECODER=n
CONFIG_AW_VIDEO_GOOGLE_DECODER=n

# =============================================================================
# GPU — Imagination PowerVR BXM-4-64 MC1
# pvrsrvkm.ko is built automatically when bsp/ is present (bsp/modules/gpu/).
# Disable conflicting DRM drivers from the base defconfig.
# DEVFREQ_GOV_SIMPLE_ONDEMAND: required for GPU DVFS support in pvrsrvkm.
# =============================================================================

# Disable mainline DRM drivers that conflict with BSP GPU (base defconfig enables these)
CONFIG_DRM_PANFROST=n
CONFIG_DRM_LIMA=n
# Disable upstream open PowerVR driver if present — we use the BSP pvrsrvkm instead
CONFIG_DRM_IMAGINATION=n

# GPU DVFS governor — pvrsrvkm checks for this at init
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
