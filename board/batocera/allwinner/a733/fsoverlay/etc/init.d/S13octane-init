#!/bin/sh
# OctaneOS init: install dev SSH key to the correct path.
# Root home in Batocera is /userdata/system — Dropbear looks there for
# authorized_keys, not /root/.ssh. Runs after S12populateshare.

DEV_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEmEFho+A+VIZNyOogCAiL2ZpGoGFY8v8Fu4/TdwYb4u octaneos-dev"

case "$1" in
  start)
    # Batocera sets root shell to /bin/dash; profile scripts use bash syntax → Bad substitution
    sed -i 's|:/bin/dash$|:/bin/bash|' /etc/passwd

    # S26system falls back to first 2 chars of system.language ("en" from en_US) when
    # system.kblayout is unset. "en" is not a valid loadkeys layout; "us" is correct.
    BATOCERA_CONF=/userdata/system/batocera.conf
    if ! grep -q "^system.kblayout=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.kblayout=us" >> "$BATOCERA_CONF"
    fi
    if ! grep -q "^system.hostname=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.hostname=OctaneOS" >> "$BATOCERA_CONF"
    fi

    # Disable the ES screensaver. The default screensaver fires after 5 min idle and
    # attempts video playback which hangs the compositor on A733 (no HW video decode).
    # system.screensaver.time=0 → "Never" in the ES UI.
    # system.screensaver.behavior=black → safe fallback if user re-enables.
    if ! grep -q "^system.screensaver.time=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.screensaver.time=0" >> "$BATOCERA_CONF"
    fi
    if ! grep -q "^system.screensaver.behavior=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.screensaver.behavior=black" >> "$BATOCERA_CONF"
    fi

    # Disable xpad auto-poweroff. The built-in xpad driver defaults auto_poweroff=Y
    # which sends an Xbox360 "power off" command to idle controllers. 8BitDo in
    # Xbox360 mode (045e:028e) interprets this as a reset and drops the USB connection.
    # The controller reconnects immediately but ES loses its input calibration state.
    echo N > /sys/bus/usb/drivers/xpad/module/parameters/auto_poweroff 2>/dev/null || true

    # Disable USB autosuspend for devices that must not drop.
    #   a69c:8800/8801 — AIC8800 WiFi dongle: driver doesn't implement suspend/resume,
    #                    kernel hangs on resume attempt.
    #   1a86:8091      — QinHeng USB hub on Cubie A7S: if the hub autosuspends it
    #                    drops every device under it (WiFi + controllers).
    #   045e:*         — Microsoft/8BitDo Xbox360-mode controllers: reconnects during
    #                    ES init cause the input axis calibration to be read wrong,
    #                    inverting joystick2 volume hotkey direction.
    for dev in /sys/bus/usb/devices/*; do
        vid=$(cat "$dev/idVendor" 2>/dev/null)
        pid=$(cat "$dev/idProduct" 2>/dev/null)
        if [ "$vid" = "a69c" ] && { [ "$pid" = "8800" ] || [ "$pid" = "8801" ]; }; then
            echo on > "$dev/power/control" 2>/dev/null || true
        elif [ "$vid" = "1a86" ] && [ "$pid" = "8091" ]; then
            echo on > "$dev/power/control" 2>/dev/null || true
        elif [ "$vid" = "045e" ]; then
            echo on > "$dev/power/control" 2>/dev/null || true
        fi
    done

    # Timezone: default to US Pacific if not set. Batocera's squashfs bakes in
    # Europe/Paris and S26system only applies the timezone if system.timezone is
    # already present in batocera.conf — so on a fresh flash the device boots
    # showing Paris time. Set a sensible default; user can override via ES Settings.
    if ! grep -q "^system.timezone=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.timezone=America/Los_Angeles" >> "$BATOCERA_CONF"
    fi
    TZ_SETTING=$(grep "^system.timezone=" "$BATOCERA_CONF" 2>/dev/null | cut -d= -f2)
    if [ -n "$TZ_SETTING" ] && [ -f "/usr/share/zoneinfo/$TZ_SETTING" ]; then
        ln -sf "/usr/share/zoneinfo/$TZ_SETTING" /etc/localtime
        echo "$TZ_SETTING" > /etc/timezone
    fi

    # Enable RetroAchievements by default. The user just needs to add their
    # retroachievements.org credentials via Game Settings in the ES menu.
    # Hardcore mode off by default — friendlier for first-time users.
    if ! grep -q "^global.retroachievements=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "global.retroachievements=1" >> "$BATOCERA_CONF"
    fi
    if ! grep -q "^global.retroachievements.hardcore=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "global.retroachievements.hardcore=0" >> "$BATOCERA_CONF"
    fi

    # Install ROM Transfer port entry. Copies from squashfs template so it
    # survives OS upgrades — always reflects the current version of the script.
    PORTS_DIR=/userdata/roms/ports
    TRANSFER_SCRIPT="$PORTS_DIR/ROM Transfer.sh"
    mkdir -p "$PORTS_DIR"
    cp /usr/share/octane/rom-transfer.sh "$TRANSFER_SCRIPT"
    chmod +x "$TRANSFER_SCRIPT"

    SSH_DIR=/userdata/system/.ssh
    AUTH_KEYS=$SSH_DIR/authorized_keys
    mkdir -p -m 0700 "$SSH_DIR"
    if ! grep -qF "octaneos-dev" "$AUTH_KEYS" 2>/dev/null; then
        echo "$DEV_KEY" >> "$AUTH_KEYS"
        chmod 0600 "$AUTH_KEYS"
    fi
    ;;
esac

exit 0
